{
  "name": "subscription-reconciler",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Ashutosh Sharma",
  "type": "module",
  "engines": {
    "node": "24.16.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "deps:cycles": "madge --circular --extensions ts --ts-config tsconfig.json src",
    "check": "npm run typecheck && npm run lint && npm run deps:cycles",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrations/runner.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.4",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "kysely": "0.29.2",
    "node-cron": "4.2.1",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testcontainers/postgresql": "12.0.1",
    "@types/node": "24.12.4",
    "@types/node-cron": "3.0.11",
    "@types/pg": "8.20.0",
    "madge": "8.0.0",
    "tsx": "4.22.3",
    "typescript": "5.9.2",
    "vitest": "4.1.7"
  }
}
